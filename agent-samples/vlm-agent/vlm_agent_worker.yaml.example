# VLM agent worker configuration.
# Auto-discovered by the launcher and passed as --config to the worker process.

# HuggingFace model ID. Any model supported by AutoModelForImageTextToText works.
# nvidia/Cosmos-Reason1-7B  — no login required, Apache 2.0 + NVIDIA Open Model License
# nvidia/Cosmos-Reason2-8B  — requires HuggingFace login and license acceptance (see below)
model: nvidia/Cosmos-Reason2-8B

# HuggingFace token — required for gated models (e.g. Cosmos-Reason2-8B).
# Accept the license at https://huggingface.co/nvidia/Cosmos-Reason2-8B first.
# Alternative: set the HF_TOKEN environment variable instead.
# !! Do not commit this file with a real token !!
hf_token: ""

# System prompt passed to the model before each query.
# Leave empty or omit to use no system prompt.
system_prompt: ""
