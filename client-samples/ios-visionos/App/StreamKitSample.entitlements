<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- visionOS main-camera passthrough — requires Apple enterprise entitlement.
         Without it, startCamera() will throw an access-denied error on device.
         All other features (audio, data channel) work without this entitlement. -->
    <key>com.apple.developer.arkit.main-camera-access.allow</key>
    <true/>
</dict>
</plist>
